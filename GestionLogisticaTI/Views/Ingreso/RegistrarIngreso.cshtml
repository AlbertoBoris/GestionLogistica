@model GestionLogisticaTI.ViewModels.IngresoViewModel

<h2 class="mb-1">
    <i class="bi bi-box-arrow-in-down"></i>
    Registrar Ingreso de Mercadería
</h2>
<h6 class="mb-4 text-secondary">
    Control de ingresos al almacén
</h6>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

<div class="card">

    <div class="card-body">

        <form method="post">

            <div class="row">

                <div class="col-md-4 mb-3">

                    <label class="form-label">
                        <i class="bi bi-file-earmark-text"></i>
                        Número Documento
                    </label>

                    <input name="NumeroDocumento"
                           class="form-control"
                           placeholder="Factura / Guía" />
                    <span id="errNumeroDocumento" class="text-danger" style="font-size: 12px;"></span>
                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-chat-left-text"></i>
                        Motivo (Opcional)
                    </label>

                    <input name="Motivo"
                           class="form-control"
                           placeholder="Motivo del ingreso" />

                </div>

            </div>

            <hr>

            <h5 class="mb-3">
                <i class="bi bi-box-seam"></i>
                Productos
            </h5>

            <table class="table table-striped align-middle" id="tablaProductos">

                <thead class="table-dark">

                    <tr>
                        <th width="50%">Producto</th>
                        <th width="20%">Cantidad</th>
                        <th width="10%"></th>
                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>

                            <select name="Detalles[0].IdProducto"
                                    class="form-control productoSelect">

                                @foreach (var p in Model.Productos)
                                {
                                    <option value="@p.IdProducto">@p.Nombre</option>
                                }

                            </select>

                        </td>

                        <td>

                            <input type="number"
                                   name="Detalles[0].Cantidad"
                                   class="form-control cantidad"
                                   min="1" />
                            <span class="text-danger err-cantidad" style="font-size: 11px;"></span>
                        </td>

                        <td>

                            <button type="button"
                                    class="btn btn-danger eliminarFila">

                                <i class="bi bi-trash"></i>

                            </button>

                        </td>

                    </tr>

                </tbody>

            </table>

            <div class="mb-3">

                <strong>Total unidades ingresadas:</strong>
                <span id="totalUnidades" class="badge bg-primary">0</span>

            </div>

            <button type="button"
                    class="btn btn-secondary"
                    id="btnAgregar">

                <i class="bi bi-plus-circle"></i>
                Agregar Producto

            </button>

            <hr>

            <button class="btn btn-success">

                <i class="bi bi-check-circle"></i>
                Registrar Ingreso

            </button>

            <a href="@Url.Action("Index","Producto")"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Cancelar

            </a>

        </form>

    </div>

</div>



@section scripts{

    <script>

let index = 1;

function calcularTotal(){

let total = 0;

document.querySelectorAll(".cantidad").forEach(input => {

let val = parseInt(input.value);

if(!isNaN(val))
total += val;

});

document.getElementById("totalUnidades").innerText = total;

}

function validarDuplicados(){

let productos = [];

document.querySelectorAll(".productoSelect").forEach(select => {

if(productos.includes(select.value)){

alert("Este producto ya fue agregado");

select.value = "";

}

productos.push(select.value);

});

}

$("#btnAgregar").click(function(){

let tabla = $("#tablaProductos tbody");

let fila = `

<tr>

<td>

<select name="Detalles[${index}].IdProducto"
class="form-control productoSelect">

@foreach (var p in Model.Productos)
{
<text>
<option value="@p.IdProducto">@p.Nombre</option>
</text>
}

</select>

</td>

<td>

<input type="number"
name="Detalles[${index}].Cantidad"
class="form-control cantidad"
min="1"/>

</td>

<td>

<button type="button"
class="btn btn-danger eliminarFila">

<i class="bi bi-trash"></i>

</button>

</td>

</tr>

`;

tabla.append(fila);

$(".productoSelect").select2({
width:'100%'
});

index++;

});

$(document).on("click",".eliminarFila",function(){

$(this).closest("tr").remove();

calcularTotal();

});

$(document).on("input",".cantidad",function(){

if(this.value < 0){

alert("La cantidad no puede ser negativa");

this.value = "";

}

calcularTotal();

});

$(document).on("change",".productoSelect",function(){

validarDuplicados();

});

$(document).ready(function(){

$(".productoSelect").select2({
width:'100%'
});

});

        $("form").on("submit", function (e) {
            let esValido = true;

            $(".text-danger").text("");
            $(".form-control").removeClass("is-invalid");

            const inputDoc = $("input[name='NumeroDocumento']");
            const valDoc = inputDoc.val().trim();
            if (valDoc.length !== 8 || isNaN(valDoc)) {
                $("#errNumeroDocumento").text(" El documento debe tener exactamente 8 números.");
                inputDoc.addClass("is-invalid");
                esValido = false;
            }

            const totalFilas = $("#tablaProductos tbody tr").length;
            if (totalFilas === 0) {
               
                esValido = false;
            }

            $(".cantidad").each(function () {
                const cant = parseInt($(this).val());
                const spanError = $(this).siblings(".err-cantidad"); 

                if (isNaN(cant) || cant <= 0) {
                    spanError.text("La cantidad de ser mayor a 0");
                    $(this).addClass("is-invalid");
                    esValido = false;
                }
            });

            if (!esValido) {
                e.preventDefault();
                e.stopImmediatePropagation();
                $("#loaderOverlay").hide(); 
                return false;
            }
        });
    
    </script>
    
}








