@model GestionLogisticaTI.ViewModels.PedidoDespachoDetalleViewModel

<h2 class="mb-4">
    <i class="bi bi-truck"></i>
    Confirmar Despacho
</h2>


<div class="card mb-4">

    <div class="card-body">

        <div class="row">

            <div class="col-md-3">

                <strong>ID Pedido</strong><br />

                <span class="badge bg-secondary">
                    #@Model.IdPedido
                </span>

            </div>

            <div class="col-md-3">

                <strong>Fecha Pedido</strong><br />

                @Model.Fecha.ToString("dd/MM/yyyy")

            </div>

            <div class="col-md-3">

                @if (Model.FechaDespacho != null)
                {
                    <strong>Fecha Despacho</strong><br />

                    <span class="text-success">
                        <i class="bi bi-check-circle"></i>
                        @Model.FechaDespacho.Value.ToString("dd/MM/yyyy HH:mm")
                    </span>
                }

            </div>

            <div class="col-md-3">

                <strong>Cliente</strong><br />

                <i class="bi bi-person"></i>
                @Model.Cliente

            </div>

        </div>

    </div>

</div>



<div class="card mb-4">

    <div class="card-body">

        <h5 class="mb-3">
            <i class="bi bi-box-seam"></i>
            Productos del Pedido
        </h5>

        <table id="tablaDespachoDetalle"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>Producto</th>
                    <th width="120">Cantidad</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model.Detalles)
                {
                    <tr>

                        <td>
                            <i class="bi bi-box"></i>
                            @item.Producto
                        </td>

                        <td>
                            <span class="badge bg-info">
                                @item.Cantidad
                            </span>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>



<div class="card">

    <div class="card-body">

        <h5 class="mb-3">
            <i class="bi bi-file-earmark-text"></i>
            Datos del Despacho
        </h5>

        @using (Html.BeginForm("Confirmar", "Despacho", FormMethod.Post))
        {

            <input type="hidden" name="idPedido" value="@Model.IdPedido" />

            <div class="row">

                <div class="col-md-4">

                    <label class="form-label">
                        Número de Guía
                    </label>

                    <input type="text"
                           name="numeroDocumento"
                           class="form-control"
                           placeholder="Ingrese número de guía"
                           required />

                </div>

            </div>

            <div class="mt-3">

                <button type="submit"
                        class="btn btn-success">

                    <i class="bi bi-truck"></i>
                    Confirmar Despacho

                </button>

                <a href="@Url.Action("Index")"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>
                    Volver

                </a>

            </div>

        }

    </div>

</div>

@section scripts{

    <script>

$(document).ready(function(){

$('#tablaDespachoDetalle').DataTable({

searching:false,
lengthChange:false,
info:false,
paging:false,

language:{
url:"//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
}

});

});

    </script>

}