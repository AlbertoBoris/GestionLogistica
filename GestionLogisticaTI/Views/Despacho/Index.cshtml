@model List<GestionLogisticaTI.ViewModels.PedidoDespachoViewModel>

@{
    var total = Model.Count();
    var urgentes = Model.Count(x => x.Fecha >= DateTime.Now.AddHours(-2));
    var recientes = Model.Count(x => x.Fecha >= DateTime.Now.AddDays(-1));
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="mb-1">
            <i class="bi bi-truck"></i>
            Confirmar Despacho
        </h2>
        <h6 class="text-secondary mb-0">
            Confirmación de despachos de pedidos autorizados
        </h6>
    </div>

    <div class="d-flex gap-3">

        <div class="text-center">
            <small class="text-muted">Pendientes</small>
            <div class="fw-bold">@total</div>
        </div>

        <div class="text-center">
            <small class="text-muted">Urgentes</small>
            <div class="fw-bold text-danger">@urgentes</div>
        </div>

        <div class="text-center">
            <small class="text-muted">Últimas 24h</small>
            <div class="fw-bold text-primary">@recientes</div>
        </div>

    </div>

</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle"></i>
        @TempData["Error"]
    </div>
}


<div class="card">

    <div class="card-body">

        <table id="tablaDespachos"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th style="display:none;">Orden</th>
                    <th>ID Pedido</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Items</th>
                    <th width="180">Acción</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="@(item.Fecha >= DateTime.Now.AddHours(-2) ? "table-danger" :
             item.Fecha >= DateTime.Now.AddDays(-1) ? "table-info" : "")">

                        <td style="display:none;">
                            @(
        item.Fecha >= DateTime.Now.AddHours(-2) ? 1 :
        item.Fecha >= DateTime.Now.AddDays(-1) ? 2 : 3
    )
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                #@item.IdPedido
                            </span>
                        </td>

                        <td data-order="@item.Fecha.ToString("yyyy-MM-dd HH:mm:ss")">

                            @item.Fecha.ToString("dd/MM/yyyy")

                            @if (item.Fecha >= DateTime.Now.AddHours(-2))
                            {
                                <span class="badge bg-danger ms-1">Urgente</span>
                            }
                            else if (item.Fecha >= DateTime.Now.AddDays(-1))
                            {
                                <span class="badge bg-info ms-1">Nuevo</span>
                            }

                        </td>

                        <td>
                            <i class="bi bi-person"></i>
                            @item.Cliente
                        </td>

                        <td>
                            <span class="badge bg-info">
                                @item.CantidadItems
                            </span>
                        </td>

                        <td>

                            <a href="@Url.Action("Detalle", new { id = item.IdPedido })"
                               class="btn btn-success btn-sm"
                               title="Confirmar despacho"
                               onclick="return confirmarDespacho();">

                                <i class="bi bi-truck"></i>
                                Confirmar

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaDespachos').DataTable({

                pageLength: 10,
                searching: false,
                lengthChange: false,
                info: false,

                order: [
                    [0, "asc"], // prioridad
                    [2, "desc"] // fecha
                ],

                columnDefs: [
                    { targets: 0, visible: false },
                    { targets: -1, orderable: false }
                ],

                deferRender: true,
                processing: true,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

    </script>

}