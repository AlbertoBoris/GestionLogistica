@model GestionLogisticaTI.ViewModels.ClienteViewModel

<h2 class="mb-4">
    <i class="bi bi-person-plus"></i>
    Nuevo Cliente
</h2>

@Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

@using (Html.BeginForm())
{

    <div class="card">

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-person"></i>
                        Nombre
                    </label>

                    @Html.TextBoxFor(m => m.Nombre,
                        new { @class = "form-control", placeholder = "Nombre del cliente" })

                    @Html.ValidationMessageFor(m => m.Nombre,
                        "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-credit-card"></i>
                        RUC / DNI
                    </label>

                    @Html.TextBoxFor(m => m.RucDni,
                        new { @class = "form-control", placeholder = "Ingrese RUC o DNI" })

                    @Html.ValidationMessageFor(m => m.RucDni,
                        "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-telephone"></i>
                        Teléfono
                    </label>

                    @Html.TextBoxFor(m => m.Telefono,
                        new { @class = "form-control", placeholder = "Número de teléfono" })

                    @Html.ValidationMessageFor(m => m.Telefono,
                        "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-geo-alt"></i>
                        Dirección
                    </label>

                    @Html.TextBoxFor(m => m.Direccion,
                        new { @class = "form-control", placeholder = "Dirección del cliente" })

                    @Html.ValidationMessageFor(m => m.Direccion,
                        "", new { @class = "text-danger" })

                </div>

            </div>

        </div>

    </div>


    <div class="mt-3">

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i>
            Guardar
        </button>

        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Volver
        </a>

    </div>

}