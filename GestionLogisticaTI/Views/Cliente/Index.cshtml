@model List<GestionLogisticaTI.ViewModels.ClienteViewModel>
@{
    var total = Model.Count();
    var activos = Model.Count(x => x.EsActivo);
    var inactivos = total - activos;
}
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="mb-1">
            <i class="bi bi-people"></i>
            Gestión de Clientes
        </h2>
        <h6 class="text-secondary mb-0">
            Administración de clientes registrados en el sistema
        </h6>
    </div>

    <div class="d-flex gap-3">

        <div class="text-center">
            <small class="text-muted">Total</small>
            <div class="fw-bold">@total</div>
        </div>

        <div class="text-center">
            <small class="text-muted">Activos</small>
            <div class="fw-bold text-success">@activos</div>
        </div>

        <div class="text-center">
            <small class="text-muted">Inactivos</small>
            <div class="fw-bold text-secondary">@inactivos</div>
        </div>

    </div>

</div>

<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "Cliente", FormMethod.Get))
        {

            <div class="row">

                <div class="col-md-4 mb-2">

                    <input type="text"
                           name="nombre"
                           value="@ViewBag.FiltroNombre"
                           class="form-control"
                           placeholder="Buscar por nombre" />

                </div>

                <div class="col-md-3 mb-2">

                    <select name="estado" class="form-control">

                        <option value="">-- Todos --</option>

                        <option value="Activo"
                                @(ViewBag.FiltroEstado == "Activo" ? "selected" : "")>
                            Activo
                        </option>

                        <option value="Inactivo"
                                @(ViewBag.FiltroEstado == "Inactivo" ? "selected" : "")>
                            Inactivo
                        </option>

                    </select>

                </div>

                <div class="col-md-2 mb-2">

                    <button type="submit"
                            class="btn btn-primary w-100">

                        <i class="bi bi-search"></i>
                        Buscar

                    </button>

                </div>

                <div class="col-md-2 mb-2">

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary w-100">

                        <i class="bi bi-x-circle"></i>
                        Limpiar

                    </a>

                </div>

                <div class="col-md-1 mb-2">

                    <a href="@Url.Action("Create")"
                       class="btn btn-success w-100">

                        <i class="bi bi-person-plus"></i>

                    </a>

                </div>

            </div>

        }

    </div>

</div>



<div class="card">

    <div class="card-body">

        <table id="tablaClientes"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>Nombre</th>
                    <th>RUC / DNI</th>
                    <th>Teléfono</th>
                    <th>Dirección</th>
                    <th>Estado</th>
                    <th width="180">Acciones</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                   <tr class="@(item.EsActivo ? "" : "table-light text-muted")">

                       <td>
                           <i class="bi bi-person"></i>
                           @item.Nombre
                       </td>

                       <td>
                           @item.RucDni
                       </td>

                       <td>
                           <i class="bi bi-telephone"></i>
                           @item.Telefono
                       </td>

                       <td>
                           <i class="bi bi-geo-alt"></i>
                           @item.Direccion
                       </td>

                       <td>

                           @if (item.EsActivo)
                           {
                               <span class="badge bg-success">
                                   Activo
                               </span>
                           }
                           else
                           {
                               <span class="badge bg-secondary ms2">
                                   Inactivo
                               </span>
                           }

                       </td>

                       <td>

                           <a href="@Url.Action("Edit", new { id = item.IdCliente })"
                              class="btn btn-warning btn-sm" title="Esitar Cliente">

                               <i class="bi bi-pencil"></i>

                           </a>

                           <a href="@Url.Action("CambiarEstado", new { id = item.IdCliente })"
                              class="btn btn-secondary btn-sm"
                              onclick="return confirm('¿Desea cambiar el estado del cliente?');" title="Cambiar Estado">

                               <i class="bi bi-arrow-repeat"></i>

                           </a>

                       </td>

                   </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaClientes').DataTable({

                pageLength: 10,

                searching: false,
                lengthChange: false,
                info: false,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

    </script>

}