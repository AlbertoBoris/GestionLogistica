@model GestionLogisticaTI.ViewModels.PedidoCreateViewModel

@{
    ViewBag.Title = "Editar Pedido";
    var index = 0;
}

<h2 class="mb-4">
    <i class="bi bi-pencil-square"></i>
    Editar Pedido
</h2>


@using (Html.BeginForm("Edit", "Pedido", FormMethod.Post))
{

    @Html.HiddenFor(m => m.IdPedido)


    <div class="card mb-4">
        <div class="card-body">

            <div class="row">

                <div class="col-md-4">

                    <label class="form-label">Cliente</label>

                    @Html.DropDownListFor(m => m.IdCliente,
                    Model.Clientes,
                    "-- Seleccione Cliente --",
                    new { @class = "form-control" })

                </div>

            </div>

        </div>
    </div>



    <div class="card mb-4">

        <div class="card-body">

            <h5>
                <i class="bi bi-box-seam"></i>
                Agregar Productos
            </h5>

            <div class="row">

                <div class="col-md-5">

                    @Html.DropDownList("productoSelect",
                    Model.Productos,
                    "-- Producto --",
                    new { @class = "form-control", id = "productoSelect" })

                </div>

                <div class="col-md-3">

                    <input type="number"
                           id="cantidadInput"
                           class="form-control"
                           placeholder="Cantidad"
                           min="1" />

                </div>

                <div class="col-md-2">

                    <button type="button"
                            class="btn btn-success"
                            onclick="agregarProducto()">

                        <i class="bi bi-plus-circle"></i>
                        Agregar

                    </button>

                </div>

            </div>

        </div>

    </div>



    <div class="card">

        <div class="card-body">

            <table class="table table-striped align-middle"
                   id="tablaDetalle">

                <thead class="table-dark">

                    <tr>
                        <th>Producto</th>
                        <th width="120">Cantidad</th>
                        <th width="80">Acción</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model.Detalles != null)
                    {
                        foreach (var item in Model.Detalles)
                        {
                            <tr>

                                <td>
                                    @item.Producto

                                    <input type="hidden"
                                           name="Detalles[@index].IdProducto"
                                           value="@item.IdProducto" />

                                </td>

                                <td>

                                    @item.Cantidad

                                    <input type="hidden"
                                           name="Detalles[@index].Cantidad"
                                           value="@item.Cantidad" />

                                </td>

                                <td>

                                    <button type="button"
                                            class="btn btn-danger btn-sm"
                                            onclick="eliminarFila(this)">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </td>

                            </tr>

                            index++;
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div id="mensajeError" class="alert alert-danger" style="display:none;"></div>

    <div class="mt-3">

        <button type="button" id="btnActualizar" class="btn btn-primary">
            <i class="bi bi-save"></i>
            Actualizar Pedido
        </button>

        <a href="@Url.Action("Index")"
           class="btn btn-secondary">

            <i class="bi bi-arrow-left"></i>
            Volver

        </a>

    </div>

}

@section scripts{

    <script>

var index = @index;

function mostrarError(mensaje){
    let div = document.getElementById("mensajeError");
    div.innerText = mensaje;
    div.style.display = "block";
}

function limpiarError(){
    let div = document.getElementById("mensajeError");
    div.innerText = "";
    div.style.display = "none";
}

function agregarProducto(){

    limpiarError();

    var productoSelect = document.getElementById("productoSelect");
    var cantidadInput = document.getElementById("cantidadInput");

    var productoValor = productoSelect.value;
    var productoTexto = productoSelect.options[productoSelect.selectedIndex].text;
    var cantidad = cantidadInput.value;

    // validar producto
    if(productoValor === ""){
        mostrarError("Seleccione un producto.");
        return;
    }

    // validar cantidad
    if(cantidad === "" || parseInt(cantidad) <= 0){
        mostrarError("Ingrese una cantidad válida.");
        return;
    }

    // evitar duplicados (incluye los ya cargados)
    let existe = false;

    document.querySelectorAll("#tablaDetalle tbody input[name$='.IdProducto']")
        .forEach(function(input){
            if(input.value === productoValor){
                existe = true;
            }
        });

    if(existe){
        mostrarError("El producto ya fue agregado.");
        return;
    }

    var tabla = document.querySelector("#tablaDetalle tbody");

    var fila = tabla.insertRow();

    fila.innerHTML = `
<td>
    ${productoTexto}
    <input type="hidden" name="Detalles[${index}].IdProducto" value="${productoValor}" />
</td>

<td>
    ${cantidad}
    <input type="hidden" name="Detalles[${index}].Cantidad" value="${cantidad}" />
</td>

<td>
    <button type="button"
        class="btn btn-danger btn-sm"
        onclick="eliminarFila(this)">
        <i class="bi bi-trash"></i>
    </button>
</td>
`;

    index++;

    cantidadInput.value = "";
}

function eliminarFila(btn){
    btn.closest("tr").remove();
}


// VALIDACIÓN FINAL ANTES DE ACTUALIZAR
document.getElementById("btnActualizar").addEventListener("click", function(){

    limpiarError();

    let cliente = document.querySelector("[name='IdCliente']").value;
    let filas = document.querySelectorAll("#tablaDetalle tbody tr").length;

    if(cliente === "" || cliente === "0"){
        mostrarError("Debe seleccionar un cliente.");
        return;
    }

    if(filas === 0){
        mostrarError("Debe agregar al menos un producto.");
        return;
    }

    // enviar
    document.querySelector("form").submit();

});

    </script>

}