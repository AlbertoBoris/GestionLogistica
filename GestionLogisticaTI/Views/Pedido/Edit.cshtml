@model GestionLogisticaTI.ViewModels.PedidoCreateViewModel

@{
    ViewBag.Title = "Editar Pedido";
    var index = 0;
}

<h2 class="mb-4">
    <i class="bi bi-pencil-square"></i>
    Editar Pedido
</h2>


@using (Html.BeginForm("Edit", "Pedido", FormMethod.Post))
{

    @Html.HiddenFor(m => m.IdPedido)


    <div class="card mb-4">
        <div class="card-body">

            <div class="row">

                <div class="col-md-4">

                    <label class="form-label">Cliente</label>

                    @Html.DropDownListFor(m => m.IdCliente,
                    Model.Clientes,
                    "-- Seleccione Cliente --",
                    new { @class = "form-control" })

                </div>

            </div>

        </div>
    </div>



    <div class="card mb-4">

        <div class="card-body">

            <h5>
                <i class="bi bi-box-seam"></i>
                Agregar Productos
            </h5>

            <div class="row">

                <div class="col-md-5">

                    @Html.DropDownList("productoSelect",
                    Model.Productos,
                    "-- Producto --",
                    new { @class = "form-control", id = "productoSelect" })

                </div>

                <div class="col-md-3">

                    <input type="number"
                           id="cantidadInput"
                           class="form-control"
                           placeholder="Cantidad"
                           min="1" />

                </div>

                <div class="col-md-2">

                    <button type="button"
                            class="btn btn-success"
                            onclick="agregarProducto()">

                        <i class="bi bi-plus-circle"></i>
                        Agregar

                    </button>

                </div>

            </div>

        </div>

    </div>



    <div class="card">

        <div class="card-body">

            <table class="table table-striped align-middle"
                   id="tablaDetalle">

                <thead class="table-dark">

                    <tr>
                        <th>Producto</th>
                        <th width="120">Cantidad</th>
                        <th width="80">Acción</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model.Detalles != null)
                    {
                        foreach (var item in Model.Detalles)
                        {
                            <tr>

                                <td>
                                    @item.Producto

                                    <input type="hidden"
                                           name="Detalles[@index].IdProducto"
                                           value="@item.IdProducto" />

                                </td>

                                <td>

                                    @item.Cantidad

                                    <input type="hidden"
                                           name="Detalles[@index].Cantidad"
                                           value="@item.Cantidad" />

                                </td>

                                <td>

                                    <button type="button"
                                            class="btn btn-danger btn-sm"
                                            onclick="eliminarFila(this)">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </td>

                            </tr>

                            index++;
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>



    <div class="mt-3">

        <button type="submit"
                class="btn btn-primary">

            <i class="bi bi-save"></i>
            Actualizar Pedido

        </button>

        <a href="@Url.Action("Index")"
           class="btn btn-secondary">

            <i class="bi bi-arrow-left"></i>
            Volver

        </a>

    </div>

}

@section scripts{

    <script>

var index = @index;

function agregarProducto(){

var productoSelect = document.getElementById("productoSelect");
var cantidad = document.getElementById("cantidadInput").value;

if(productoSelect.value === "" || cantidad <= 0 || cantidad === ""){
alert("Seleccione producto y cantidad válida");
return;
}

var productoTexto = productoSelect.options[productoSelect.selectedIndex].text;
var productoValor = productoSelect.value;

var tabla = document.querySelector("#tablaDetalle tbody");

var fila = tabla.insertRow();

fila.innerHTML = `
<td>
${productoTexto}
<input type="hidden" name="Detalles[${index}].IdProducto" value="${productoValor}" />
</td>

<td>
${cantidad}
<input type="hidden" name="Detalles[${index}].Cantidad" value="${cantidad}" />
</td>

<td>
<button type="button"
class="btn btn-danger btn-sm"
onclick="eliminarFila(this)">
<i class="bi bi-trash"></i>
</button>
</td>
`;

index++;

document.getElementById("cantidadInput").value = "";

}

function eliminarFila(btn){

btn.closest("tr").remove();

}

    </script>

}