@model GestionLogisticaTI.ViewModels.PedidoCreateViewModel

@{
    ViewBag.Title = "Editar Pedido";
    var index = 0;
}

<h2>Editar Pedido</h2>

@using (Html.BeginForm("Edit", "Pedido", FormMethod.Post))
{
    @Html.HiddenFor(m => m.IdPedido)

    <div class="form-group mb-3">
        <label>Cliente</label>
        @Html.DropDownListFor(m => m.IdCliente,
                 Model.Clientes,
                 "-- Seleccione Cliente --",
                 new { @class = "form-control" })
    </div>

    <hr />

    <h4>Agregar Productos</h4>

    <div class="row mb-3">
        <div class="col-md-5">
            @Html.DropDownList("productoSelect",
                     Model.Productos,
                     "-- Producto --",
                     new { @class = "form-control", id = "productoSelect" })
        </div>

        <div class="col-md-3">
            <input type="number"
                   id="cantidadInput"
                   class="form-control"
                   placeholder="Cantidad"
                   min="1" />
        </div>

        <div class="col-md-2">
            <button type="button"
                    class="btn btn-success"
                    onclick="agregarProducto()">
                Agregar
            </button>
        </div>
    </div>

    <table class="table table-bordered" id="tablaDetalle">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>

            @if (Model.Detalles != null)
            {
                foreach (var item in Model.Detalles)
                {
                    <tr>
                        <td>
                            @item.Producto
                            <input type="hidden"
                                   name="Detalles[@index].IdProducto"
                                   value="@item.IdProducto" />
                        </td>
                        <td>
                            @item.Cantidad
                            <input type="hidden"
                                   name="Detalles[@index].Cantidad"
                                   value="@item.Cantidad" />
                        </td>
                        <td>
                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    onclick="eliminarFila(this)">
                                X
                            </button>
                        </td>
                    </tr>
                    index++;
                }
            }

        </tbody>
    </table>

    <br />

    <button type="submit" class="btn btn-primary">
        Actualizar Pedido
    </button>

    <a href="@Url.Action("Index")" class="btn btn-secondary">
        Volver
    </a>
}

@section Scripts {
    <script>
    var index = @index;

    function agregarProducto() {

        var productoSelect = document.getElementById("productoSelect");
        var cantidad = document.getElementById("cantidadInput").value;

        if (productoSelect.value === "" || cantidad <= 0 || cantidad === "") {
            alert("Seleccione producto y cantidad válida");
            return;
        }

        var productoTexto = productoSelect.options[productoSelect.selectedIndex].text;
        var productoValor = productoSelect.value;

        var tabla = document.getElementById("tablaDetalle")
                            .getElementsByTagName("tbody")[0];

        var fila = tabla.insertRow();

        fila.innerHTML =
            `<td>
                ${productoTexto}
                <input type="hidden" name="Detalles[${index}].IdProducto" value="${productoValor}" />
             </td>
             <td>
                ${cantidad}
                <input type="hidden" name="Detalles[${index}].Cantidad" value="${cantidad}" />
             </td>
             <td>
                <button type="button" class="btn btn-danger btn-sm" onclick="eliminarFila(this)">
                    X
                </button>
             </td>`;

        index++;
        document.getElementById("cantidadInput").value = "";
    }

    function eliminarFila(btn) {
        var fila = btn.parentNode.parentNode;
        fila.parentNode.removeChild(fila);
    }
    </script>
}