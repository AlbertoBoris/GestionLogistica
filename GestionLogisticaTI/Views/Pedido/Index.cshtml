@model List<GestionLogisticaTI.ViewModels.PedidoListViewModel>

<h2 class="mb-4">
    <i class="bi bi-cart"></i>
    Gestión de Pedidos
</h2>


<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "Pedido", FormMethod.Get))
        {

            <div class="row">

                <div class="col-md-4 mb-2">

                    <label class="form-label">Cliente</label>

                    @Html.DropDownList("idCliente",
                    (List<SelectListItem>)ViewBag.Clientes,
                    "-- Todos --",
                    new { @class = "form-control" })

                </div>

                <div class="col-md-3 mb-2">

                    <label class="form-label">Estado</label>

                    <select name="estado" class="form-control">

                        <option value="">-- Todos --</option>

                        <option value="Pendiente" @(ViewBag.EstadoSeleccionado == "Pendiente" ? "selected" : "")>
                            Pendiente
                        </option>

                        <option value="Autorizado" @(ViewBag.EstadoSeleccionado == "Autorizado" ? "selected" : "")>
                            Autorizado
                        </option>

                        <option value="Despachado" @(ViewBag.EstadoSeleccionado == "Despachado" ? "selected" : "")>
                            Despachado
                        </option>

                        <option value="Cancelado" @(ViewBag.EstadoSeleccionado == "Cancelado" ? "selected" : "")>
                            Cancelado
                        </option>

                    </select>

                </div>

                <div class="col-md-2 d-flex align-items-end mb-2">

                    <button type="submit"
                            class="btn btn-primary w-100">

                        <i class="bi bi-search"></i>
                        Buscar

                    </button>

                </div>

                <div class="col-md-2 d-flex align-items-end mb-2">

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary w-100">

                        <i class="bi bi-x-circle"></i>
                        Limpiar

                    </a>

                </div>

                <div class="col-md-1 d-flex align-items-end mb-2">

                    <a href="@Url.Action("Create")"
                       class="btn btn-success w-100">

                        <i class="bi bi-plus-circle"></i>

                    </a>

                </div>

            </div>

        }

    </div>

</div>



<div class="card">

    <div class="card-body">

        <table id="tablaPedidos"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>ID</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Estado</th>
                    <th>Items</th>
                    <th width="200">Acciones</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <span class="badge bg-secondary">
                                #@item.IdPedido
                            </span>
                        </td>

                        <td>
                            @item.Fecha.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            <i class="bi bi-person"></i>
                            @item.Cliente
                        </td>

                        <td>

                            @if (item.Estado == "Pendiente")
                            {
                                <span class="badge bg-warning text-dark">
                                    Pendiente
                                </span>
                            }
                            else if (item.Estado == "Autorizado")
                            {
                                <span class="badge bg-primary">
                                    Autorizado
                                </span>
                            }
                            else if (item.Estado == "Despachado")
                            {
                                <span class="badge bg-success">
                                    Despachado
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Cancelado
                                </span>
                            }

                        </td>

                        <td>
                            <span class="badge bg-info">
                                @item.CantidadItems
                            </span>
                        </td>

                        <td>

                            <a href="@Url.Action("Detalle", new { id = item.IdPedido })"
                               class="btn btn-info btn-sm">

                                <i class="bi bi-eye"></i>

                            </a>

                            @if (item.Estado == "Pendiente")
                            {

                                <a href="@Url.Action("Edit", new { id = item.IdPedido })"
                                   class="btn btn-warning btn-sm">

                                    <i class="bi bi-pencil"></i>

                                </a>

                                <a href="@Url.Action("Cancelar", new { id = item.IdPedido })"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('¿Seguro que desea cancelar el pedido?');">

                                    <i class="bi bi-x-circle"></i>

                                </a>

                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaPedidos').DataTable({

                pageLength: 10,

                searching: false,
                lengthChange: false,
                info: false,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

    </script>

}