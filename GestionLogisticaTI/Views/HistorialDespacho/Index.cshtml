@model List<GestionLogisticaTI.ViewModels.HistorialDespachoViewModel>
@{
    var total = Model.Count();
    var recientes = Model.Count(x => x.FechaDespacho.HasValue && x.FechaDespacho.Value >= DateTime.Now.AddDays(-1));
}
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="mb-1">
            <i class="bi bi-truck"></i>
            Historial de Despachos
        </h2>
        <h6 class="text-secondary mb-0">
            Consulta y trazabilidad de salidas
        </h6>
    </div>

    <div class="d-flex gap-3">

        <div class="text-center">
            <small class="text-muted">Total</small>
            <div class="fw-bold">@total</div>
        </div>

        <div class="text-center">
            <small class="text-muted">Últimas 24h</small>
            <div class="fw-bold text-primary">@recientes</div>
        </div>

    </div>

</div>


<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "HistorialDespacho", FormMethod.Get))
        {

            <div class="row align-items-end">

                <div class="col-md-3 mb-2">
                    <label class="form-label">N° Guía</label>
                    <input type="text"
                           name="numeroGuia"
                           value="@ViewBag.NumeroGuia"
                           class="form-control"
                           placeholder="Buscar..." />
                </div>

                <div class="col-md-3 mb-2">
                    <label class="form-label">Desde</label>
                    <input type="date"
                           name="fechaDesde"
                           value="@(ViewBag.FechaDesde != null ? ((DateTime)ViewBag.FechaDesde).ToString("yyyy-MM-dd") : "")"
                           class="form-control" />
                </div>

                <div class="col-md-3 mb-2">
                    <label class="form-label">Hasta</label>
                    <input type="date"
                           name="fechaHasta"
                           value="@(ViewBag.FechaHasta != null ? ((DateTime)ViewBag.FechaHasta).ToString("yyyy-MM-dd") : "")"
                           class="form-control" />
                </div>

                <div class="col-md-3 mb-2">
                    <button class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filtrar
                    </button>
                </div>

            </div>

        }

    </div>

</div>


<div class="card">

    <div class="card-body">

        <table id="tablaDespachos"
               class="table table-striped table-hover align-middle table-sm">

            <thead class="table-dark">

                <tr>
                    <th>Pedido</th>
                    <th>Cliente</th>
                    <th>Fecha Pedido</th>
                    <th>Fecha Despacho</th>
                    <th>N° Guía</th>
                    <th width="120">Acciones</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="@(item.FechaDespacho.HasValue && item.FechaDespacho.Value >= DateTime.Now.AddDays(-1) ? "table-info" : "")">

                        <td>
                            <span class="badge bg-secondary">
                                #@item.IdPedido
                            </span>
                        </td>

                        <td>
                            <i class="bi bi-person"></i>
                            @item.Cliente
                        </td>

                        <td>
                            @item.Fecha.ToString("dd/MM/yyyy")
                        </td>

                        <td data-order="@(item.FechaDespacho.HasValue ? item.FechaDespacho.Value.ToString("yyyy-MM-dd HH:mm:ss") : "")">

                            @if (item.FechaDespacho.HasValue)
                            {
                                @item.FechaDespacho.Value.ToString("dd/MM/yyyy")

                                if (item.FechaDespacho.Value >= DateTime.Now.AddHours(-2))
                                {
                                    <span class="badge bg-danger ms-1">Reciente</span>
                                }
                            }

                        </td>

                        <td>

                            @if (!string.IsNullOrEmpty(item.NumeroGuia))
                            {
                                <span class="badge bg-info">
                                    @item.NumeroGuia
                                </span>
                            }

                        </td>

                        <td>

                            <a href="@Url.Action("Detalle", new { id = item.IdPedido })"
                               class="btn btn-primary btn-sm">

                                <i class="bi bi-eye"></i>

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaDespachos').DataTable({

                pageLength: 15,
                searching: false,
                lengthChange: false,
                info: false,

                order: [[3, "desc"]],

                deferRender: true,
                processing: true,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

    </script>

}