@model GestionLogisticaTI.ViewModels.ReporteLogisticoViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <style>

        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
            margin: 30px;
            color: #333;
        }

        .header {
            border-bottom: 3px solid #2f4050;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .titulo {
            font-size: 22px;
            font-weight: bold;
            color: #2f4050;
        }

        .subtitulo {
            font-size: 15px;
            margin-top: 4px;
        }

        .info {
            margin-top: 15px;
            margin-bottom: 20px;
            line-height: 1.6;
        }

            .info strong {
                display: inline-block;
                width: 160px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        thead {
            display: table-header-group;
        }

        th {
            background: #2f4050;
            color: white;
            padding: 8px;
            border: 1px solid #ccc;
            text-align: left;
        }

        td {
            padding: 7px;
            border: 1px solid #ccc;
        }

        tbody tr:nth-child(even) {
            background: #f5f7fa;
        }

        tr {
            page-break-inside: avoid;
        }

        .resumen {
            margin-top: 20px;
            padding: 10px;
            background: #f4f6f8;
            border: 1px solid #ccc;
            font-weight: bold;
        }

        .footer {
            margin-top: 40px;
            border-top: 1px solid #ccc;
            padding-top: 8px;
            font-size: 11px;
            text-align: right;
            color: #777;
        }
    </style>

</head>

<body>

    <div class="header">

        <div class="titulo">
            Sistema de Gestión Logística TI
        </div>

        <div class="subtitulo">
            Reporte Logístico
        </div>

    </div>


    <div class="info">

        <strong>Tipo de Reporte:</strong> @Model.TipoReporte
        <br />

        @if (Model.FechaInicio != null)
        {
            <strong>Periodo:</strong>
            @Model.FechaInicio.Value.ToString("dd/MM/yyyy")
            <a>-</a>
           @Model.FechaFin.Value.ToString("dd/MM/yyyy")
<br />
}

        <strong>Generado por:</strong> @Session["Nombre"]
        <br />

        <strong>Fecha de generación:</strong>
        @DateTime.Now.ToString("dd/MM/yyyy HH:mm")

    </div>


    @if (Model.Resultados != null && Model.Resultados.Count > 0)
    {

        <table>

            <thead>
                <tr>

                    @foreach (var col in ((IDictionary<string, object>)Model.Resultados[0]).Keys)
                    {
                        <th>@col</th>
                    }

                </tr>
            </thead>

            <tbody>

                @foreach (var row in Model.Resultados)
                {
                    <tr>

                        @foreach (var value in ((IDictionary<string, object>)row).Values)
                        {
                            <td>@value</td>
                        }

                    </tr>
                }

            </tbody>

        </table>

        <div class="resumen">
            Total de registros: @Model.Resultados.Count
        </div>

    }

    <div class="footer">

        Sistema de Gestión Logística TI
        Reporte generado automáticamente por el sistema.

    </div>

</body>
</html>