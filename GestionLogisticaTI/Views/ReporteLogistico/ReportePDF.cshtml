@model GestionLogisticaTI.ViewModels.ReporteLogisticoViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <style>

        body {
            font-family: Arial;
            font-size: 12px;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #2f4050;
            padding-bottom: 10px;
        }

        .titulo {
            font-size: 20px;
            font-weight: bold;
        }

        .subtitulo {
            font-size: 14px;
            margin-top: 5px;
        }

        .info {
            margin-top: 10px;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #2f4050;
            color: white;
            padding: 8px;
            border: 1px solid #ccc;
        }

        td {
            padding: 6px;
            border: 1px solid #ccc;
        }

        tbody tr:nth-child(even) {
            background: #f4f6f8;
        }

        .resumen {
            margin-top: 15px;
            font-weight: bold;
        }

        .footer {
            margin-top: 25px;
            font-size: 11px;
            border-top: 1px solid #ccc;
            padding-top: 8px;
            text-align: right;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            display: table-header-group;
        }

        tfoot {
            display: table-footer-group;
        }

        tr {
            page-break-inside: avoid;
        }

        td, th {
            padding: 6px;
            border: 1px solid #ccc;
        }

        tbody tr:nth-child(even) {
            background: #f4f6f8;
        }

        tbody tr:hover {
            background: #e9ecef;
        }
    </style>

</head>

<body>

    <div class="header">

        <div class="titulo">
            Sistema de Gestión Logística TI
        </div>

        <div class="subtitulo">
            Reporte Logístico
        </div>

    </div>


    <div class="info">

        <strong>Tipo de Reporte:</strong> @Model.TipoReporte
        <br />

        @if (Model.FechaInicio != null)
        {
            <strong>Periodo:</strong>
            @Model.FechaInicio.Value.ToString("dd/MM/yyyy")
            <a>-</a>
           @Model.FechaFin.Value.ToString("dd/MM/yyyy")
<br />
}

        <strong>Generado por:</strong> @Session["Nombre"]
        <br />

        <strong>Fecha de generación:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")

    </div>


    @if (Model.Resultados != null && Model.Resultados.Count > 0)
    {

        <table>

            <thead>
                <tr>

                    @foreach (var col in ((IDictionary<string, object>)Model.Resultados[0]).Keys)
                    {
                        <th>@col</th>
                    }

                </tr>
            </thead>

            <tbody>

                @foreach (var row in Model.Resultados)
                {
                    <tr>

                        @foreach (var value in ((IDictionary<string, object>)row).Values)
                        {
                            <td>@value</td>
                        }

                    </tr>
                }

            </tbody>

        </table>


        <div class="resumen" style="margin-top:15px; page-break-inside: avoid;">
            Total de registros: @Model.Resultados.Count
        </div>

    }

    <div class="footer">

        Sistema de Gestión Logística TI
        Reporte generado automáticamente por el sistema.

    </div>


</body>
</html>