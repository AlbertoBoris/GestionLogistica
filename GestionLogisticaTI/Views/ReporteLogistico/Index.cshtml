@model GestionLogisticaTI.ViewModels.ReporteLogisticoViewModel

@{
    var nombresColumnas = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
{
        { "idMovimiento", "ID" },
        { "fecha", "Fecha" },
        { "tipoMovimiento", "Tipo" },
        { "numeroDocumento", "Documento" },
        { "motivo", "Motivo" },
        { "producto", "Producto" },
        { "cantidad", "Cantidad" },
        { "totalProductos", "Productos" },
        { "totalUnidades", "Unidades" },
        { "productosCriticos", "Criticos" },
        { "FechaPedido", "Fecha de Pedido" },
        { "fechaDespacho", "Fecha de Despacho" },
        { "NumeroGuia", "N° Guía" },
        { "UsuarioDespacho", "Usuario" },
        { "idPedido", "ID" },
        { "idProducto", "ID" },
        { "nombre", "Nombre" },
        { "stockActual", "Stock Actual" },
        { "stockMinimo", "Stock Minimo" },
        { "ubicacion", "Ubicación" },
        { "estado", "Estado" },
        { "usuario", "Usuario" }
    };
}
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="mb-1">
            <i class="bi bi-file-earmark-bar-graph"></i>
            Reportes Logísticos
        </h2>
        <h6 class="text-secondary mb-0">
            Generación y análisis de información operativa
        </h6>
    </div>

</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>
            <i class="bi bi-exclamation-triangle"></i>
            Corrija los siguientes errores:
        </strong>
        @Html.ValidationSummary(false)
    </div>
}

<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "ReporteLogistico", FormMethod.Get))
        {

            <div class="row">

                <div class="col-md-4 mb-2">

                    <label class="form-label">Tipo de Reporte</label>

                    @Html.DropDownListFor(m => m.TipoReporte,
                                                       Model.TiposReporte,
                                                       "-- Seleccione Reporte --",
                                                       new { @class = "form-control" })

                </div>

                <div class="col-md-2 mb-2">

                    <label class="form-label">Fecha Inicio</label>

                    <input type="date"
                           name="fechaInicio"
                           value="@(Model.FechaInicio != null ? Model.FechaInicio.Value.ToString("yyyy-MM-dd") : "")"
                           class="form-control" />

                </div>

                <div class="col-md-2 mb-2">

                    <label class="form-label">Fecha Fin</label>

                    <input type="date"
                           name="fechaFin"
                           value="@(Model.FechaFin != null ? Model.FechaFin.Value.ToString("yyyy-MM-dd") : "")"
                           class="form-control" />

                </div>

                <div class="col-md-2 d-flex align-items-end mb-2">

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-bar-chart"></i>
                        Generar Reporte
                    </button>

                </div>

                <div class="col-md-2 d-flex align-items-end mb-2">

                    @if (Model.Resultados != null && Model.Resultados.Count > 0)
                    {
                        <a class="btn btn-danger w-100"
                           href="@Url.Action("DescargarPDF","ReporteLogistico",
new {
tipoReporte = Model.TipoReporte,
fechaInicio = Model.FechaInicio,
fechaFin = Model.FechaFin
})">

                            <i class="bi bi-file-earmark-pdf"></i>
                            PDF

                        </a>
                    }

                </div>

            </div>

        }

    </div>

</div>


@if (Model.Resultados != null && Model.Resultados.Count > 0)
{

    <div class="card">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">

                <h5 class="mb-0">
                    <i class="bi bi-table"></i>
                    Vista previa del reporte
                </h5>

                <div id="excelBtnArea"></div>

            </div>

            <table id="tablaReporte"
                   class="table table-striped table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        @foreach (var col in ((IDictionary<string, object>)Model.Resultados[0]).Keys)
                        {
                            <th>
                                @(nombresColumnas.ContainsKey(col) ? nombresColumnas[col] : col)
                            </th>
                        }

                    </tr>

                </thead>

                <tbody>

                    @foreach (var row in Model.Resultados)
                    {
                        <tr>

                            @foreach (var value in ((IDictionary<string, object>)row))
                            {
                                <td>
                                    @{
                                        if (value.Value is DateTime)
                                        {
                                            @(((DateTime)value.Value).ToString("dd/MM/yyyy HH:mm"))
                                        }
                                        else
                                        {
                                            @value.Value
                                        }
                                    }
                                </td>
                            }

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

}


@section scripts{

    <script>

        $(document).ready(function () {

            var table = $('#tablaReporte').DataTable({

                pageLength: 10,
                searching: true,
                lengthChange: false,
                info: true,


                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

            // renderizar el botón en el contenedor derecho
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="bi bi-file-earmark-excel"></i> Excel',
                        className: 'btn btn-success'
                    }
                ]
            });

            table.buttons(0, null).container().appendTo('#excelBtnArea');

        });

    </script>

}