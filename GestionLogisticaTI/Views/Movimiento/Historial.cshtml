@model List<GestionLogisticaTI.ViewModels.MovimientoHistorialViewModel>

<h2 class="mb-1">
    <i class="bi bi-clock-history"></i>
    Historial de Movimientos
</h2>
<h6 class="mb-4 text-secondary">
    Consulta y trazabilidad de operaciones de inventario
</h6>

<div class="card mb-4">

    <div class="card-body">

        <form method="get">

            <div class="row">

                <div class="col-md-3 mb-2">

                    <select name="tipoMovimiento" class="form-control">

                        <option value="">Todos los movimientos</option>
                        <option value="Ingreso">Ingreso</option>
                        <option value="Salida">Salida</option>
                        <option value="Ajuste">Ajuste</option>

                    </select>

                </div>

                <div class="col-md-2 mb-2">
                    <input type="date" name="fechaInicio" class="form-control" />
                </div>

                <div class="col-md-2 mb-2">
                    <input type="date" name="fechaFin" class="form-control" />
                </div>

                <div class="col-md-3 mb-2">
                    <input type="text"
                           name="producto"
                           class="form-control"
                           placeholder="Buscar producto" />
                </div>

                <div class="col-md-2 mb-2">

                    <button class="btn btn-primary w-100">

                        <i class="bi bi-search"></i>
                        Buscar

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>


<div class="card">

    <div class="card-body">

        <table id="tablaMovimientos"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>

                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Documento</th>
                    <th>Motivo</th>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Usuario</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                        </td>

                        <td>

                            @if (item.TipoMovimiento == "Ingreso")
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-box-arrow-in-down"></i>
                                    Ingreso
                                </span>
                            }
                            else if (item.TipoMovimiento == "Salida")
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-box-arrow-up"></i>
                                    Salida
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-tools"></i>
                                    Ajuste
                                </span>
                            }

                        </td>

                        <td>
                            @item.NumeroDocumento
                        </td>

                        <td>
                            @item.Motivo
                        </td>

                        <td>
                            <i class="bi bi-box"></i>
                            @item.Producto
                        </td>

                        <td>

                            @if (item.TipoMovimiento == "Ingreso")
                            {
                                <span class="text-success fw-bold">
                                    +@item.Cantidad
                                </span>
                            }
                            else if (item.TipoMovimiento == "Salida")
                            {
                                <span class="text-danger fw-bold">
                                    -@item.Cantidad
                                </span>
                            }
                            else
                            {
                                <span class="text-warning fw-bold">
                                    @item.Cantidad
                                </span>
                            }

                        </td>

                        <td>
                            <i class="bi bi-person"></i>
                            @item.Usuario
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

$(document).ready(function(){

$('#tablaMovimientos').DataTable({

pageLength: 10,

searching:false,
lengthChange:false,

language:{
url:"//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
}

});

});

    </script>

}