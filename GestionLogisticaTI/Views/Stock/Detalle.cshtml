@model GestionLogisticaTI.ViewModels.ProductoViewModel

@{
    var esCritico = Model.StockActual <= Model.StockMinimo;
}

<div class="mb-4">

    <h2 class="mb-1">
        <i class="bi bi-box-seam"></i>
        @Model.Nombre
    </h2>

    <h6 class="text-secondary">
        Detalle del producto y estado de inventario
    </h6>

</div>

@if (esCritico)
{
    <div class="alert alert-danger d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Stock en nivel crítico</strong>
    </div>
}
else
{
    <div class="alert alert-success d-flex align-items-center">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Stock en nivel normal</strong>
    </div>
}

<div class="card mb-4">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>
                <span class="badge @(Model.Estado == "Activo" ? "bg-success" : "bg-secondary")">
                    @Model.Estado
                </span>

                <span class="badge @(esCritico ? "bg-danger" : "bg-primary") ms-1">
                    @(esCritico ? "Crítico" : "Normal")
                </span>
            </div>

        </div>

        <hr />

        <div class="row">

            <div class="col-md-8 mb-3">

                <label class="form-label fw-bold">
                    <i class="bi bi-card-text"></i>
                    Descripción
                </label>

                <div class="border rounded p-3 bg-light">
                    @if (string.IsNullOrWhiteSpace(Model.Descripcion))
                    {
                        <span class="text-muted">Sin descripción registrada.</span>
                    }
                    else
                    {
                        @Model.Descripcion
                    }
                </div>

            </div>

            <div class="col-md-4 mb-3">

                <label class="form-label fw-bold">
                    <i class="bi bi-geo-alt"></i>
                    Ubicación
                </label>

                <div class="border rounded p-3 bg-light">
                    @Model.Ubicacion
                </div>

            </div>

        </div>

    </div>

</div>

<div class="card">

    <div class="card-body">

        <h5 class="mb-3">
            <i class="bi bi-clipboard-data"></i>
            Información de Stock
        </h5>

        <div class="row text-center">

            <div class="col-md-4 mb-3">
                <div class="border rounded p-3">
                    <small class="text-muted">Stock Actual</small>
                    <div class="fs-4 fw-bold @(esCritico ? "text-danger" : "text-success")">
                        @Model.StockActual
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="border rounded p-3">
                    <small class="text-muted">Stock Mínimo</small>
                    <div class="fs-4 fw-bold">
                        @Model.StockMinimo
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="border rounded p-3">
                    <small class="text-muted">Diferencia</small>
                    <div class="fs-4 fw-bold @(esCritico ? "text-danger" : "text-primary")">
                        @(Model.StockActual - Model.StockMinimo)
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

<div class="mt-3">

    <a href="@Url.Action("Index", "Stock")"
       class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Volver
    </a>

</div>