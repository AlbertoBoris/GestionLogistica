@model List<GestionLogisticaTI.ViewModels.StockViewModel>

<h2 class="mb-1">
    <i class="bi bi-bar-chart"></i>
    Consultar Stock
</h2>
<h6 class="mb-4 text-secondary">
    Vista de inventario disponible en tiempo real
</h6>

@{
    var totalCriticos = Model.Count(x => x.EsCritico);
}

<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "Stock", FormMethod.Get))
        {

            <div class="row">

                <div class="col-md-4 mb-2">

                    <input type="text"
                           name="nombreProducto"
                           value="@ViewBag.FiltroNombre"
                           class="form-control"
                           placeholder="Buscar por producto" />

                </div>

                <div class="col-md-2 mb-2">

                    <button type="submit" class="btn btn-primary w-100">

                        <i class="bi bi-search"></i>
                        Buscar

                    </button>

                </div>


                <div class="col-md-2 mb-2">

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary w-100">

                        <i class="bi bi-x-circle"></i>
                        Limpiar

                    </a>

                </div>

            </div>

        }

    </div>

</div>

@if (totalCriticos > 0)
{
    <div class="alert alert-danger d-flex align-items-center">

        <i class="bi bi-exclamation-triangle-fill me-2"></i>

        <strong>
            @totalCriticos producto(s) en estado crítico
        </strong>

    </div>
}
else
{
    <div class="alert alert-success d-flex align-items-center">

        <i class="bi bi-check-circle-fill me-2"></i>

        <strong>
            Todo el inventario está en estado óptimo
        </strong>

    </div>
}


<div class="card">

    <div class="card-body">

        <table id="tablaStock"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th style="display:none;">Critico</th>
                    <th>Producto</th>
                    <th>Stock Actual</th>
                    <th>Stock Mínimo</th>
                    <th>Ubicación</th>
                    <th>Estado</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="@(item.EsCritico ? "table-danger" : "")">

                        <td style="display:none;">
                            @(item.EsCritico ? 1 : 0)
                        </td>

                        <td>

                            <i class="bi bi-box"></i>
                            @item.Producto

                        </td>

                        <td>

                            @if (item.EsCritico)
                            {
                                <span class="badge bg-danger">
                                    @item.StockActual
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    @item.StockActual
                                </span>
                            }

                        </td>

                        <td>
                            @item.StockMinimo
                        </td>

                        <td>

                            <i class="bi bi-geo-alt"></i>
                            @item.Ubicacion

                        </td>

                        <td>

                            @if (item.EsCritico)
                            {
                                <span class="badge bg-danger">

                                    <i class="bi bi-exclamation-triangle"></i>
                                    Crítico

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">

                                    <i class="bi bi-check-circle"></i>
                                    Normal

                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaStock').DataTable({

                pageLength: 10,
                searching: false,
                lengthChange: false,
                info: false,

                order: [[0, "desc"]], // 👈 columna oculta (críticos primero)

                columnDefs: [
                    { targets: 0, visible: false } // 👈 ocultar columna
                ],

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });
        });

    </script>

}