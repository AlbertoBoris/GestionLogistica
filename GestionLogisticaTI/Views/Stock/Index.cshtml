@model List<GestionLogisticaTI.ViewModels.StockViewModel>

<h2 class="mb-4">
    <i class="bi bi-bar-chart"></i>
    Consultar Stock
</h2>


<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "Stock", FormMethod.Get))
        {

            <div class="row">

                <div class="col-md-4 mb-2">

                    <input type="text"
                           name="nombreProducto"
                           value="@ViewBag.FiltroNombre"
                           class="form-control"
                           placeholder="Buscar por producto" />

                </div>

                <div class="col-md-2 mb-2">

                    <button type="submit" class="btn btn-primary w-100">

                        <i class="bi bi-search"></i>
                        Buscar

                    </button>

                </div>

                <div class="col-md-2 mb-2">

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary w-100">

                        <i class="bi bi-x-circle"></i>
                        Limpiar

                    </a>

                </div>

            </div>

        }

    </div>

</div>


<div class="card">

    <div class="card-body">

        <table id="tablaStock"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>Producto</th>
                    <th>Stock Actual</th>
                    <th>Stock Mínimo</th>
                    <th>Ubicación</th>
                    <th>Estado</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="@(item.EsCritico ? "table-danger" : "")">

                        <td>

                            <i class="bi bi-box"></i>
                            @item.Producto

                        </td>

                        <td>

                            @if (item.EsCritico)
                            {
                                <span class="badge bg-danger">
                                    @item.StockActual
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    @item.StockActual
                                </span>
                            }

                        </td>

                        <td>
                            @item.StockMinimo
                        </td>

                        <td>

                            <i class="bi bi-geo-alt"></i>
                            @item.Ubicacion

                        </td>

                        <td>

                            @if (item.EsCritico)
                            {
                                <span class="badge bg-danger">

                                    <i class="bi bi-exclamation-triangle"></i>
                                    Crítico

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">

                                    <i class="bi bi-check-circle"></i>
                                    Normal

                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

$(document).ready(function(){

$('#tablaStock').DataTable({

pageLength:10,

searching:false,
lengthChange:false,
info:false,

language:{
url:"//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
}

});

});

    </script>

}