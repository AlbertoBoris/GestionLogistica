@model List<GestionLogisticaTI.ViewModels.StockViewModel>

<h2>Consultar Stock</h2>

@using (Html.BeginForm("Index", "Stock", FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text"
                   name="nombreProducto"
                   value="@ViewBag.FiltroNombre"
                   class="form-control"
                   placeholder="Buscar por producto" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">
                Buscar
            </button>
        </div>

        <div class="col-md-2">
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                Limpiar
            </a>
        </div>
    </div>
}

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>Producto</th>
            <th>Stock Actual</th>
            <th>Stock Mínimo</th>
            <th>Ubicación</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.EsCritico ? "table-danger" : "")">
                <td>@item.Producto</td>
                <td>@item.StockActual</td>
                <td>@item.StockMinimo</td>
                <td>@item.Ubicacion</td>
                <td>
                    @if (item.EsCritico)
                    {
                        <span class="text-danger">
                            <i class="fa fa-exclamation-triangle"></i>
                            Crítico
                        </span>
                    }
                    else
                    {
                        <span class="text-success">
                            <i class="fa fa-check-circle"></i>
                            Normal
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>