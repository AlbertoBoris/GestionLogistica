@model GestionLogisticaTI.ViewModels.UsuarioViewModel

<h2 class="mb-4">
    <i class="bi bi-person-gear"></i>
    Editar Usuario
</h2>



@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>
            <i class="bi bi-exclamation-triangle"></i>
            Corrija los siguientes errores:
        </strong>
        @Html.ValidationSummary(false)
    </div>
}
@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

@Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

@using (Html.BeginForm())
{

    @Html.HiddenFor(m => m.IdUsuario)

    <div class="card">

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-person"></i>
                        Nombre
                    </label>

                    @Html.TextBoxFor(m => m.Nombre,
                        new { @class = "form-control", placeholder = "Nombre del usuario" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-envelope"></i>
                        Correo
                    </label>

                    @Html.TextBoxFor(m => m.Correo,
                        new { @class = "form-control", placeholder = "correo@empresa.com" })
                    @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-person-badge"></i>
                        Rol
                    </label>

                    @Html.DropDownListFor(m => m.IdRol,
                        Model.Roles,
                        "-- Seleccione Rol --",
                        new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.IdRol, "", new { @class = "text-danger" })

                </div>

            </div>


            <hr />


            <h5 class="mb-3">
                <i class="bi bi-lock"></i>
                Cambiar Contraseña
            </h5>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        Nueva Contraseña (opcional)
                    </label>

                    @Html.PasswordFor(m => m.Password,
                        new
                        {
                            @class = "form-control",
                            placeholder = "Dejar vacío si no desea cambiarla"
                        })

                </div>

            </div>

        </div>

    </div>


    <div class="mt-3">

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i>
            Guardar Cambios
        </button>

        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Cancelar
        </a>

    </div>

}