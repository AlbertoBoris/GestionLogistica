@model GestionLogisticaTI.ViewModels.UsuarioViewModel
@Html.ValidationSummary(true)

<h2>Editar Usuario</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(m => m.IdUsuario)

    <div class="form-group mb-3">
        <label>Nombre</label>
        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
    </div>

    <div class="form-group mb-3">
        <label>Correo</label>
        @Html.TextBoxFor(m => m.Correo, new { @class = "form-control" })
    </div>

    <div class="form-group mb-3">
        <label>Rol</label>
        @Html.DropDownListFor(m => m.IdRol,
                      Model.Roles,
                      "-- Seleccione Rol --",
                      new { @class = "form-control" })
    </div>

    <hr />

    <div class="form-group mb-3">
        <label>Nueva Contraseña (opcional)</label>
        @Html.PasswordFor(m => m.Password,
                      new { @class = "form-control", placeholder = "Dejar vacío si no desea cambiarla" })
    </div>

    <button type="submit" class="btn btn-primary">
        Guardar Cambios
    </button>

    <a href="@Url.Action("Index")" class="btn btn-secondary">
        Cancelar
    </a>
}