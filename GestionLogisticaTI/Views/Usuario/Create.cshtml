@model GestionLogisticaTI.ViewModels.UsuarioViewModel

<h2 class="mb-4">
    <i class="bi bi-person-plus"></i>
    Nuevo Usuario
</h2>

@Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

@using (Html.BeginForm())
{

    <div class="card">

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-person"></i>
                        Nombre
                    </label>

                    @Html.TextBoxFor(m => m.Nombre,
                        new { @class = "form-control", placeholder = "Nombre del usuario" })

                    @Html.ValidationMessageFor(m => m.Nombre,
                        "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-envelope"></i>
                        Correo
                    </label>

                    @Html.TextBoxFor(m => m.Correo,
                        new { @class = "form-control", placeholder = "correo@empresa.com" })

                    @Html.ValidationMessageFor(m => m.Correo,
                        "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-lock"></i>
                        Contraseña
                    </label>

                    @Html.PasswordFor(m => m.Password,
                        new { @class = "form-control", placeholder = "Ingrese contraseña" })

                    @Html.ValidationMessageFor(m => m.Password,
                        "", new { @class = "text-danger" })

                </div>


                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-person-badge"></i>
                        Rol
                    </label>

                    @Html.DropDownListFor(m => m.IdRol,
                        Model.Roles,
                        "-- Seleccione Rol --",
                        new { @class = "form-control" })

                    @Html.ValidationMessageFor(m => m.IdRol,
                        "", new { @class = "text-danger" })

                </div>

            </div>

        </div>

    </div>


    <div class="mt-3">

        <button type="submit" class="btn btn-success">
            <i class="bi bi-save"></i>
            Guardar Usuario
        </button>

        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Volver
        </a>

    </div>

}