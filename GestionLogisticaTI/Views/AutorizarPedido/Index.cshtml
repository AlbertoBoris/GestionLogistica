@model List<GestionLogisticaTI.ViewModels.PedidoAutorizacionViewModel>

<h2 class="mb-1">
    <i class="bi bi-check2-square"></i>
    Autorizar Pedidos
</h2>
<h6 class="mb-4 text-secondary">
    Revisión y autorización de pedidos pendientes
</h6>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle"></i>
        @TempData["Error"]
    </div>
}

<div class="card">

    <div class="card-body">

        <table id="tablaPedidos"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>ID Pedido</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Items</th>
                    <th width="200">Acciones</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <span class="badge bg-secondary">
                                #@item.IdPedido
                            </span>
                        </td>

                        <td>
                            @item.Fecha.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            <i class="bi bi-person"></i>
                            @item.Cliente
                        </td>

                        <td>
                            <span class="badge bg-info">
                                @item.CantidadItems
                            </span>
                        </td>

                        <td>

                            <a href="@Url.Action("Detalle", new { id = item.IdPedido })"
                               class="btn btn-info btn-sm">

                                <i class="bi bi-eye"></i>

                            </a>

                            <a href="@Url.Action("Autorizar", new { id = item.IdPedido })"
                               class="btn btn-success btn-sm"
                               onclick="return confirmarAutorizacion();">

                                <i class="bi bi-check-circle"></i>

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaPedidos').DataTable({

                pageLength: 10,

                searching: false,
                lengthChange: false,
                info: false,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

        function confirmarAutorizacion() {

            return confirm("¿Desea autorizar este pedido?");

        }

    </script>

}