@model GestionLogisticaTI.ViewModels.PedidoAutorizacionViewModel

<h2 class="mb-4">
    <i class="bi bi-receipt"></i>
    Detalle del Pedido
</h2>

<div class="card mb-4">

    <div class="card-body">

        <div class="row">

            <div class="col-md-3">
                <strong>ID Pedido</strong><br />
                <span class="badge bg-secondary">
                    #@Model.IdPedido
                </span>
            </div>

            <div class="col-md-3">
                <strong>Fecha</strong><br />
                @Model.Fecha.ToString("dd/MM/yyyy")
            </div>

            <div class="col-md-6">
                <strong>Cliente</strong><br />
                <i class="bi bi-person"></i>
                @Model.Cliente
            </div>

        </div>

    </div>

</div>


<div class="card">

    <div class="card-body">

        <h5 class="mb-3">
            <i class="bi bi-box-seam"></i>
            Productos del Pedido
        </h5>

        <table id="tablaDetalle"
               class="table table-striped table-hover align-middle">

            <thead class="table-dark">

                <tr>
                    <th>Producto</th>
                    <th>Cantidad Pedida</th>
                    <th>Stock Disponible</th>
                    <th>Estado</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in ViewBag.Detalles)
                {
                    <tr>

                        <td>
                            <i class="bi bi-box"></i>
                            @item.Producto
                        </td>

                        <td>
                            <span class="badge bg-info">
                                @item.Cantidad
                            </span>
                        </td>

                        <td>
                            @item.StockActual
                        </td>

                        <td>

                            @if (item.StockActual >= item.Cantidad)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i>
                                    Disponible
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle"></i>
                                    Sin stock
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<div class="mt-3">

    <a href="@Url.Action("Autorizar", new { id = Model.IdPedido })"
       class="btn btn-success"
       onclick="return confirmarAutorizacion();">

        <i class="bi bi-check-circle"></i>
        Autorizar Pedido

    </a>

    <a href="@Url.Action("Index")"
       class="btn btn-secondary">

        <i class="bi bi-arrow-left"></i>
        Volver

    </a>

</div>

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaDetalle').DataTable({

                searching: false,
                lengthChange: false,
                info: false,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

        function confirmarAutorizacion() {
            return confirm("¿Autorizar este pedido?");
        }

    </script>

}