@model GestionLogisticaTI.ViewModels.AjusteInventarioViewModel

<h2 class="mb-4">
    <i class="bi bi-tools"></i>
    Ajuste de Inventario
</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

<div class="card">

    <div class="card-body">

        <form method="post">

            <div class="row">

                <div class="col-md-4 mb-3">

                    <label class="form-label">
                        <i class="bi bi-file-earmark-text"></i>
                        Número de Documento
                    </label>

                    <input name="NumeroDocumento"
                           class="form-control"
                           required />

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-chat-left-text"></i>
                        Motivo del ajuste
                    </label>

                    <input name="Motivo"
                           class="form-control"
                           required />

                </div>

            </div>

            <hr>

            <h5 class="mb-3">
                <i class="bi bi-box-seam"></i>
                Productos
            </h5>

            <table class="table table-striped align-middle" id="tablaAjuste">

                <thead class="table-dark">
                    <tr>
                        <th width="30%">Producto</th>
                        <th width="15%">Stock Actual</th>
                        <th width="15%">Ajuste</th>
                        <th width="15%">Stock Final</th>
                        <th width="5%"></th>
                    </tr>
                </thead>

                <tbody>

                    <tr>

                        <td>
                            <select name="Detalles[0].IdProducto"
                                    class="form-control productoSelect">

                                @foreach (var p in Model.Productos)
                                {
                                    <option value="@p.IdProducto">@p.Nombre</option>
                                }

                            </select>
                        </td>

                        <td>
                            <input type="text"
                                   class="form-control stockActual"
                                   readonly />
                        </td>

                        <td>
                            <input type="number"
                                   name="Detalles[0].CantidadAjuste"
                                   class="form-control ajusteCantidad" />
                        </td>

                        <td>
                            <input type="text"
                                   class="form-control stockFinal"
                                   readonly />
                        </td>

                        <td>
                            <button type="button"
                                    class="btn btn-danger eliminarFila">

                                <i class="bi bi-trash"></i>

                            </button>
                        </td>

                    </tr>

                </tbody>

            </table>

            <button type="button"
                    class="btn btn-secondary"
                    id="btnAgregar">

                <i class="bi bi-plus-circle"></i>
                Agregar Producto

            </button>

            <hr>

            <button class="btn btn-warning">

                <i class="bi bi-tools"></i>
                Registrar Ajuste

            </button>

            <a href="@Url.Action("Index","Producto")"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Cancelar

            </a>

        </form>

    </div>
</div>

@section scripts{

    <script>

let index = 1;

function actualizarStockFinal(fila){

let stock = parseInt(fila.find(".stockActual").val()) || 0;
let ajuste = parseInt(fila.find(".ajusteCantidad").val()) || 0;

fila.find(".stockFinal").val(stock + ajuste);

}

$("#btnAgregar").click(function(){

let tabla = $("#tablaAjuste tbody");

let fila = `

<tr>

<td>

<select name="Detalles[${index}].IdProducto"
class="form-control productoSelect">

@foreach(var p in Model.Productos)
{
<text>
<option value="@p.IdProducto">@p.Nombre</option>
</text>
}

</select>

</td>

<td>
<input type="text"
class="form-control stockActual"
readonly />
</td>

<td>
<input type="number"
name="Detalles[${index}].CantidadAjuste"
class="form-control ajusteCantidad"/>
</td>

<td>
<input type="text"
class="form-control stockFinal"
readonly />
</td>

<td>
<button type="button"
class="btn btn-danger eliminarFila">

<i class="bi bi-trash"></i>

</button>
</td>

</tr>
`;

tabla.append(fila);

$(".productoSelect").select2({ width:'100%' });

index++;

});

$(document).on("click",".eliminarFila",function(){

$(this).closest("tr").remove();

});

$(document).on("change",".productoSelect",function(){

let fila = $(this).closest("tr");
let idProducto = $(this).val();

fetch("/Ajuste/ObtenerStock?idProducto=" + idProducto)
.then(res => res.json())
.then(stock => {

fila.find(".stockActual").val(stock);

actualizarStockFinal(fila);

});

});

$(document).on("input",".ajusteCantidad",function(){

let fila = $(this).closest("tr");

actualizarStockFinal(fila);

});

$(document).ready(function(){

$(".productoSelect").select2({
width:'100%'
});

});

    </script>

}