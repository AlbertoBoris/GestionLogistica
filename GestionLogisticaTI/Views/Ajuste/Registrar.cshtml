@model GestionLogisticaTI.ViewModels.AjusteInventarioViewModel

<h2 class="mb-1">
    <i class="bi bi-tools"></i>
    Ajuste de Inventario
</h2>
<h6 class="mb-4 text-secondary">
    Registro de ajustes manuales de stock
</h6>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

<div class="card">

    <div class="card-body">

        <form method="post" novalidate>

            <div class="row">

                <div class="col-md-4 mb-3">

                    <label class="form-label">
                        <i class="bi bi-file-earmark-text"></i>
                        Número de Documento
                    </label>

                    <input name="NumeroDocumento"
                           id="txtNumeroDocumento"
                           class="form-control"
                           required />
                    <span id="errNumeroDocumento" class="text-danger" style="font-size: 12px;"></span>
                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-chat-left-text"></i>
                        Motivo del ajuste
                    </label>

                    <input name="Motivo"
                           id="txtMotivo"
                           class="form-control"
                           required />
                    <span id="errMotivo" class="text-danger" style="font-size: 12px;"></span>
                </div>

            </div>

            <hr>

            <h5 class="mb-3">
                <i class="bi bi-box-seam"></i>
                Productos
            </h5>

            <table class="table table-striped align-middle" id="tablaAjuste">

                <thead class="table-dark">
                    <tr>
                        <th width="30%">Producto</th>
                        <th width="15%">Stock Actual</th>
                        <th width="15%">Ajuste</th>
                        <th width="15%">Stock Final</th>
                        <th width="5%"></th>
                    </tr>
                </thead>

                <tbody>

                    <tr>

                        <td>
                            <select name="Detalles[0].IdProducto"
                                    class="form-control productoSelect">

                                @foreach (var p in Model.Productos)
                                {
                                    <option value="@p.IdProducto">@p.Nombre</option>
                                }

                            </select>
                        </td>

                        <td>
                            <input type="text"
                                   class="form-control stockActual"
                                   readonly />
                        </td>

                        <td>
                            <input type="number"
                                   name="Detalles[0].CantidadAjuste"
                                   class="form-control ajusteCantidad" />
                            <span class="text-danger err-especifico" style="font-size: 10px; display: block;"></span>
                        </td>

                        <td>
                            <input type="text"
                                   class="form-control stockFinal"
                                   readonly />
                        </td>

                        <td>
                            <button type="button"
                                    class="btn btn-danger eliminarFila">

                                <i class="bi bi-trash"></i>

                            </button>
                        </td>

                    </tr>

                </tbody>

            </table>

            <button type="button"
                    class="btn btn-secondary"
                    id="btnAgregar">

                <i class="bi bi-plus-circle"></i>
                Agregar Producto

            </button>
            <div id="errTablaVacia" class="text-danger" style="font-size: 12px; margin-top: 5px;"></div>

            <hr>
                        <!--
                    <button class="btn btn-warning">

                    <i class="bi bi-tools"></i>
                    Registrar Ajuste

                </button>

                    -->
            <button type="button" class="btn btn-warning" id="btnEjecutarAjuste">
                <i class="bi bi-tools"></i> Registrar Ajuste
            </button>

            <a href="@Url.Action("Index","Producto")"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Cancelar

            </a>

        </form>

    </div>
</div>

@section scripts{

    <script>

let index = 1;

function actualizarStockFinal(fila){

let stock = parseInt(fila.find(".stockActual").val()) || 0;
let ajuste = parseInt(fila.find(".ajusteCantidad").val()) || 0;

fila.find(".stockFinal").val(stock + ajuste);

}

$("#btnAgregar").click(function(){

let tabla = $("#tablaAjuste tbody");

let fila = `

<tr>

<td>

<select name="Detalles[${index}].IdProducto"
class="form-control productoSelect">

@foreach(var p in Model.Productos)
{
<text>
<option value="@p.IdProducto">@p.Nombre</option>
</text>
}

</select>

</td>

<td>
<input type="text"
class="form-control stockActual"
readonly />
</td>

<td>
<input type="number"
name="Detalles[${index}].CantidadAjuste"
class="form-control ajusteCantidad"/>
</td>

<td>
<input type="text"
class="form-control stockFinal"
readonly />
</td>

<td>
<button type="button"
class="btn btn-danger eliminarFila">

<i class="bi bi-trash"></i>

</button>
</td>

</tr>
`;

tabla.append(fila);

$(".productoSelect").select2({ width:'100%' });

index++;

});

$(document).on("click",".eliminarFila",function(){

$(this).closest("tr").remove();

});

$(document).on("change",".productoSelect",function(){

let fila = $(this).closest("tr");
let idProducto = $(this).val();

fetch("/Ajuste/ObtenerStock?idProducto=" + idProducto)
.then(res => res.json())
.then(stock => {

fila.find(".stockActual").val(stock);

actualizarStockFinal(fila);

});

});

$(document).on("input",".ajusteCantidad",function(){

let fila = $(this).closest("tr");

actualizarStockFinal(fila);

});

$(document).ready(function(){

$(".productoSelect").select2({
width:'100%'
});

});
    
        $("#btnEjecutarAjuste").click(function (e) {
            let esValido = true;

            let doc = $("#txtNumeroDocumento").val().trim();

            let regex = /^[a-zA-Z0-9]{1,16}$/;

            $(".text-danger").text("");
            $(".form-control").removeClass("is-invalid");

            const filas = $("#tablaAjuste tbody tr").length;
            if (filas === 0) {
                $("#errTablaVacia").text("No se puede registrar un ajuste sin productos.");
                esValido = false;
            }

            $(".ajusteCantidad").each(function () {

                const fila = $(this).closest("tr");
                const ajuste = parseInt($(this).val()) || 0;
                const stock = parseInt(fila.find(".stockActual").val()) || 0;

                const mensajeError = $(this).siblings(".err-especifico");

                if (ajuste === 0) {
                    $(this).addClass("is-invalid");
                    mensajeError.text("El ajuste no puede ser 0.");
                    esValido = false;
                }

                if (stock + ajuste < 0) {
                    $(this).addClass("is-invalid");
                    mensajeError.text("No puede dejar stock negativo.");
                    esValido = false;
                }

            });

            if (!regex.test(doc)) {
                $("#errNumeroDocumento").text("Máximo 16 caracteres (letras y números).");
                $("#txtNumeroDocumento").addClass("is-invalid");
                esValido = false;
            }

            if ($("#txtMotivo").val().trim() === "") {
                $("#errMotivo").text(" El motivo es obligatorio.");
                $("#txtMotivo").addClass("is-invalid");
                esValido = false;
            }

            if (esValido) {
                console.log("Todo correcto, enviando formulario...");
                $(this).closest("form").submit();
            } else {
                console.log("Faltan datos, deteniendo envío.");
                if ($("#loaderOverlay").length > 0) $("#loaderOverlay").hide();
                e.preventDefault();
                return false;
            }
        }); 

    </script>

}