@model GestionLogisticaTI.ViewModels.ProductoViewModel

<h2 class="mb-4">
    <i class="bi bi-plus-circle"></i>
    Registrar Producto
</h2>

<div class="card">

    <div class="card-body">

        @using (Html.BeginForm())
        {

            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-box"></i>
                        Nombre
                    </label>

                    @Html.TextBoxFor(m => m.Nombre,
                    new { @class = "form-control", placeholder = "Ingrese el nombre del producto" })

                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })

                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-geo-alt"></i>
                        Ubicación
                    </label>

                    @Html.TextBoxFor(m => m.Ubicacion,
                    new { @class = "form-control", placeholder = "Ej: Rack A1" })

                    @Html.ValidationMessageFor(m => m.Ubicacion, "", new { @class = "text-danger" })

                </div>

            </div>


            <div class="row">

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        <i class="bi bi-hash"></i>
                        Stock Mínimo
                    </label>

                    @Html.TextBoxFor(m => m.StockMinimo,
                    new { @class = "form-control", type = "number" })

                    @Html.ValidationMessageFor(m => m.StockMinimo, "", new { @class = "text-danger" })

                </div>

            </div>


            <div class="mb-3">

                <label class="form-label">
                    <i class="bi bi-card-text"></i>
                    Descripción
                </label>

                @Html.TextAreaFor(m => m.Descripcion,
                new
                {
                @class = "form-control",
                rows = 3,
                placeholder = "Descripción del producto"
                })

                @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })

            </div>


            <hr />

            <button class="btn btn-success">

                <i class="bi bi-check-circle"></i>
                Guardar

            </button>

            <a href="@Url.Action("Index")" class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Cancelar

            </a>

        }

    </div>

</div>
@section Scripts {
    <script>
        $(document).ready(function () {
           
            $("form").on("submit", function (e) {
                let esValido = true;
              
                const nombreInput = $("#Nombre");
                const nombreError = $("span[data-valmsg-for='Nombre']");
                const regexNombre = /^[a-zA-Z0-9 ]+$/;
                if (!regexNombre.test(nombreInput.val())) {
                    nombreError.text("El nombre no permite caracteres especiales.");
                    nombreInput.addClass("is-invalid");
                    esValido = false;
                }

                const stockInput = $("#StockMinimo");
                const stockError = $("span[data-valmsg-for='StockMinimo']");
                if (parseInt(stockInput.val()) < 0 || stockInput.val() === "") {
                    stockError.text("El stock no puede ser negativo o vacío.");
                    stockInput.addClass("is-invalid");
                    esValido = false;
                }

                const ubiInput = $("#Ubicacion");
                const ubiError = $("span[data-valmsg-for='Ubicacion']");
                const regexUbi = /^Rack [A-Z][1-9]$/;
                if (!regexUbi.test(ubiInput.val())) {
                    ubiError.text("Formato requerido: 'Rack A1'.");
                    ubiInput.addClass("is-invalid");
                    esValido = false;
                }

                if (!esValido) {
                    e.preventDefault();

                    
                    $("#loaderOverlay").hide();

                    return false;
                }
            });

            $("#Nombre, #StockMinimo, #Ubicacion").on("input", function () {
                $(this).removeClass("is-invalid");
                $("span[data-valmsg-for='" + $(this).attr('id') + "']").text("");
            });
        });
    </script>
}