@{
    ViewBag.Title = "Menu JefeArea";
}

<div class="sidebar-section">

    <div class="sidebar-header jefe-header">
        <i class="bi bi-person-badge"></i>
        <span>Jefe de Área</span>
    </div>

    <ul class="nav flex-column sidebar-menu">

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="Dashboard" ? "active" : "")"
               href="@Url.Action("Index","Dashboard")">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard Logistico</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="ReporteLogistico" ? "active" : "")"
               href="@Url.Action("Index","ReporteLogistico")">
                <i class="bi bi-bar-chart-line"></i>
                <span>Reportes Logisticos</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="Movimiento" ? "active" : "")"
               href="@Url.Action("Historial","Movimiento")">
                <i class="bi bi-activity"></i>
                <span>Historial de Movimientos</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="Stock" ? "active" : "")"
               href="@Url.Action("Index","Stock")">
                <i class="bi bi-box"></i>
                <span>Consultar Stock</span>
            </a>
        </li>

    </ul>

</div>