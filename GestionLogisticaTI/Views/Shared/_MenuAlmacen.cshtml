@{
    ViewBag.Title = "Menu Almacen";
}

<div class="sidebar-section">

    <div class="sidebar-header almacen-header">
        <i class="bi bi-building"></i>
        <span>Área Almacén</span>
    </div>

    <ul class="nav flex-column sidebar-menu">

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="Despacho" ? "active" : "")"
               href="@Url.Action("Index","Despacho")">
                <i class="bi bi-truck"></i>
                <span>Confirmar Despachos</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="HistorialDespacho" ? "active" : "")"
               href="@Url.Action("Index","HistorialDespacho")">
                <i class="bi bi-clock-history"></i>
                <span>Historial de Despachos</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="Auditoria" ? "active" : "")"
               href="@Url.Action("Index","Auditoria")">
                <i class="bi bi-search"></i>
                <span>Auditoría de Inventario</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString()=="Stock" ? "active" : "")"
               href="@Url.Action("Index","Stock")">
                <i class="bi bi-box-seam"></i>
                <span>Consultar Stock</span>
            </a>
        </li>

    </ul>

</div>