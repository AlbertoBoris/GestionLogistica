@model List<GestionLogisticaTI.ViewModels.AuditoriaViewModel>

<h2>Auditoría de Inventario</h2>

@using (Html.BeginForm("Index", "Auditoria", FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text"
                   name="ubicacion"
                   value="@ViewBag.Ubicacion"
                   class="form-control"
                   placeholder="Filtrar por ubicación" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">
                Filtrar
            </button>
        </div>
    </div>
}

@using (Html.BeginForm("Aplicar", "Auditoria", FormMethod.Post))
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Ubicación</th>
                <th>Stock Sistema</th>
                <th>Stock Físico</th>
                <th>Diferencia</th>
            </tr>
        </thead>
        <tbody>
            @{
                int index = 0;
            }

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.Nombre
                        <input type="hidden" name="[@index].IdProducto" value="@item.IdProducto" />
                        <input type="hidden" name="[@index].StockActual" value="@item.StockActual" />
                    </td>
                    <td>@item.Ubicacion</td>
                    <td>@item.StockActual</td>
                    <td>
                        <input type="number"
                               name="[@index].StockFisico"
                               class="form-control stockFisico"
                               data-stock="@item.StockActual"
                               oninput="calcularDiferencia(this)" />
                    </td>
                    <td class="diferencia text-center">0</td>
                </tr>

                index++;
            }
        </tbody>
    </table>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="alert alert-info">
                Total productos revisados:
                <strong id="totalRevisados">0</strong>
            </div>
        </div>

        <div class="col-md-4">
            <div class="alert alert-warning">
                Total diferencias:
                <strong id="totalDiferencias">0</strong>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-danger">
        Aplicar Auditoría
    </button>
}

<script>
    function calcularDiferencia(input) {

        var stockSistema = parseInt(input.getAttribute("data-stock"));
        var stockFisico = input.value === "" ? null : parseInt(input.value);

        var fila = input.closest("tr");
        var celdaDiferencia = fila.querySelector(".diferencia");

        if (stockFisico === null) {
            celdaDiferencia.innerText = "0";
            celdaDiferencia.classList.remove("text-danger");
            actualizarTotales();
            return;
        }

        var diferencia = stockFisico - stockSistema;
        celdaDiferencia.innerText = diferencia;

        if (diferencia !== 0) {
            celdaDiferencia.classList.add("text-danger");
        } else {
            celdaDiferencia.classList.remove("text-danger");
        }

        actualizarTotales();
    }

    function actualizarTotales() {

        var inputs = document.querySelectorAll(".stockFisico");
        var totalRevisados = 0;
        var totalDiferencias = 0;

        inputs.forEach(function (input) {

            if (input.value !== "") {
                totalRevisados++;

                var stockSistema = parseInt(input.getAttribute("data-stock"));
                var stockFisico = parseInt(input.value);

                if (stockFisico !== stockSistema) {
                    totalDiferencias++;
                }
            }
        });

        document.getElementById("totalRevisados").innerText = totalRevisados;
        document.getElementById("totalDiferencias").innerText = totalDiferencias;
    }
</script>