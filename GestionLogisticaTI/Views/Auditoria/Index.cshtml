@model List<GestionLogisticaTI.ViewModels.AuditoriaViewModel>

<h2 class="mb-1">
    <i class="bi bi-clipboard-data"></i>
    Auditoría de Inventario
</h2>
<h6 class="mb-4 text-secondary">
    Comparación stock sistema vs físico
</h6>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i>
        @TempData["Mensaje"]
    </div>
}

<div class="card mb-4">

    <div class="card-body">

        @using (Html.BeginForm("Index", "Auditoria", FormMethod.Get))
        {

            <div class="row">

                <div class="col-md-4 mb-2">

                    <input type="text"
                           name="ubicacion"
                           value="@ViewBag.Ubicacion"
                           class="form-control"
                           placeholder="Filtrar por ubicación" />

                </div>

                <div class="col-md-2 mb-2">

                    <button type="submit"
                            class="btn btn-primary w-100">

                        <i class="bi bi-search"></i>
                        Filtrar

                    </button>

                </div>

            </div>

        }

    </div>

</div>

@using (Html.BeginForm("Aplicar", "Auditoria", FormMethod.Post, new { id = "formAuditoria" }))
{

    <div class="card">

        <div class="card-body">

            <table id="tablaAuditoria"
                   class="table table-striped table-hover align-middle">

                <thead class="table-dark">

                    <tr>
                        <th>Producto</th>
                        <th>Ubicación</th>
                        <th>Stock Sistema</th>
                        <th>Stock Físico</th>
                        <th>Diferencia</th>
                    </tr>

                </thead>

                <tbody>

                    @{
                        int index = 0;
                    }

                    @foreach (var item in Model)
                    {

                        <tr>

                            <td>

                                <i class="bi bi-box"></i>
                                @item.Nombre

                                <input type="hidden"
                                       name="[@index].IdProducto"
                                       value="@item.IdProducto" />

                                <input type="hidden"
                                       name="[@index].StockActual"
                                       value="@item.StockActual" />

                            </td>

                            <td>

                                <i class="bi bi-geo-alt"></i>
                                @item.Ubicacion

                            </td>

                            <td>

                                <span class="badge bg-secondary">
                                    @item.StockActual
                                </span>

                            </td>

                            <td>

                                <input type="number"
                                       name="[@index].StockFisico"
                                       class="form-control stockFisico"
                                       data-stock="@item.StockActual"
                                       oninput="calcularDiferencia(this); validarStock(this);"
                                       min="0" />

                            </td>

                            <td class="diferencia text-center fw-bold">

                                <span class="badge bg-light text-dark">
                                    0
                                </span>

                            </td>

                        </tr>

                        index++;

                    }

                </tbody>

            </table>

        </div>

    </div>



    <div class="row mt-3">

        <div class="col-md-4">

            <div class="alert alert-info">

                <i class="bi bi-box"></i>

                Productos revisados:

                <strong id="totalRevisados">
                    0
                </strong>

            </div>

        </div>


        <div class="col-md-4">

            <div class="alert alert-warning">

                <i class="bi bi-exclamation-triangle"></i>

                Diferencias detectadas:

                <strong id="totalDiferencias">
                    0
                </strong>

            </div>

        </div>

    </div>

    <div id="errorAuditoria"
         class="alert alert-danger"
         style="display:none;">
    </div>

    <button type="submit"
            class="btn btn-danger mt-2">

        <i class="bi bi-check-circle"></i>
        Aplicar Auditoría

    </button>

}

@section scripts{

    <script>

        $(document).ready(function () {

            $('#tablaAuditoria').DataTable({

                pageLength: 10,

                searching: false,
                lengthChange: false,

                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json"
                }

            });

        });

        document.addEventListener('keypress', function (e) {
            if (e.target.classList.contains('stockFisico')) {
                if (e.key === '-') {
                    e.preventDefault();
                }
            }
        });

        $('#formAuditoria').on('submit', function (e) {

            let hayError = false;

            $('.stockFisico').each(function () {

                if (this.value !== "" && parseInt(this.value) < 0) {
                    hayError = true;
                    $(this).addClass("is-invalid");
                }

            });

            if (hayError) {

                $('#errorAuditoria')
                    .text("No se permiten valores negativos.")
                    .show();

                e.preventDefault();
                return false;
            }

            var table = $('#tablaAuditoria').DataTable();
            table.page.len(-1).draw();

        });

        function validarStock(input) {

            let valor = input.value;

            if (valor !== "" && parseInt(valor) < 0) {

                input.classList.add("is-invalid");

                // opcional: corregir automáticamente
                input.value = 0;

            } else {
                input.classList.remove("is-invalid");
            }
        }

        function calcularDiferencia(input) {

            var stockSistema = parseInt(input.getAttribute("data-stock"));
            var stockFisico = input.value === "" ? null : parseInt(input.value);

            var fila = input.closest("tr");
            var celda = fila.querySelector(".diferencia");

            if (stockFisico === null) {

                celda.innerHTML =
                    '<span class="badge bg-light text-dark">0</span>';

                actualizarTotales();
                return;

            }

            var diferencia = stockFisico - stockSistema;

            if (diferencia === 0) {

                celda.innerHTML =
                    '<span class="badge bg-success">0</span>';

            }

            else if (diferencia > 0) {

                celda.innerHTML =
                    '<span class="badge bg-primary">+' + diferencia + '</span>';

            }

            else {

                celda.innerHTML =
                    '<span class="badge bg-danger">' + diferencia + '</span>';

            }

            actualizarTotales();

        }



        function actualizarTotales() {

            var table = $('#tablaAuditoria').DataTable();

            var totalRevisados = 0;
            var totalDiferencias = 0;

            table.$('.stockFisico').each(function () {

                if (this.value !== "") {

                    totalRevisados++;

                    var stockSistema = parseInt(this.getAttribute("data-stock"));
                    var stockFisico = parseInt(this.value);

                    if (stockFisico !== stockSistema) {
                        totalDiferencias++;
                    }

                }

            });

            $('#totalRevisados').text(totalRevisados);
            $('#totalDiferencias').text(totalDiferencias);

        }

    </script>

}